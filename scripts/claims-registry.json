{
  "_doc": "Each claim ties a number/string that appears in prose to a generated source of truth. check-claims.mjs verifies the rendered value is present in every listed file and that no competing value of the same shape appears. Sources: 'stats' = conformance-stats.json (golden suite), 'accuracy' = packages/caelus/accuracy.json. PATCHES.md is intentionally excluded everywhere: it is a historical changelog that records superseded values on purpose.",
  "claims": [
    {
      "id": "golden-check-count",
      "source": "stats.checks",
      "render": [
        "{value}"
      ],
      "competing": "\\b\\d,\\d{3}\\b(?=[^\\n]{0,40}(golden|check|fixture))",
      "appearsIn": [
        "ARCHITECTURE.md",
        "apps/web/app/notes/page.tsx",
        "apps/web/app/page.tsx",
        "apps/web/app/validation/page.tsx",
        "apps/web/public/llms.txt",
        "llms.txt",
        "packages/caelus/README.md"
      ],
      "format": "thousands"
    },
    {
      "id": "worst-diff-nano-prose",
      "source": "stats.worst.nano_arcsec",
      "round": 2,
      "render": [
        "{value} nano-arcsecond"
      ],
      "competing": "(\\d+\\.\\d+)\\s*nano-arcsecond",
      "appearsIn": [
        "packages/caelus/README.md",
        "apps/web/app/page.tsx",
        "apps/web/app/validation/page.tsx",
        "apps/web/app/notes/page.tsx"
      ]
    },
    {
      "id": "worst-diff-nano-llms",
      "source": "stats.worst.nano_arcsec",
      "round": 2,
      "render": [
        "{value}e-9 arcsec"
      ],
      "competing": "(\\d+\\.\\d+)e-9 arcsec",
      "appearsIn": [
        "apps/web/public/llms.txt",
        "llms.txt"
      ]
    },
    {
      "id": "true-node-bound",
      "source": "accuracy.true_node_vs_builtin",
      "render": [
        "true node ≤ {value}",
        "true node <= 1'"
      ],
      "competing": "true node [≤<=]+ ?1[″\\\"]",
      "appearsIn": [
        "packages/caelus/README.md",
        "MCP_SPEC.md",
        "packages/caelus-mcp/src/server.ts",
        "llms.txt",
        "apps/web/public/llms.txt"
      ]
    },
    {
      "id": "house-system-count",
      "source": "accuracy.counts.house_systems",
      "render": [
        "{value} house systems",
        "{value} systems",
        "twelve house systems",
        "Twelve house systems"
      ],
      "appearsIn": [
        "apps/web/app/features/page.tsx",
        "apps/web/app/page.tsx",
        "apps/web/app/docs/data-tiers/page.mdx",
        "python/README.md"
      ]
    },
    {
      "id": "sidereal-ayanamsa-count",
      "source": "accuracy.counts.sidereal_ayanamsas",
      "render": [
        "{value} sidereal",
        "{value} ayanamsas",
        "seven sidereal",
        "seven ayanamsas"
      ],
      "competing": "(\\b\\d+|six|seven|eight|nine|ten|eleven|twelve) (sidereal|ayanamsa)",
      "appearsIn": [
        "apps/web/app/features/page.tsx",
        "apps/web/app/page.tsx",
        "apps/web/app/docs/data-tiers/page.mdx",
        "ROADMAP.md",
        "python/README.md"
      ]
    },
    {
      "id": "mcp-tool-count",
      "source": "accuracy.counts.mcp_tools",
      "render": [
        "{value} chart tools",
        "seventeen chart tools",
        "Seventeen chart tools",
        "seventeen tools"
      ],
      "appearsIn": [
        "apps/web/app/features/page.tsx",
        "apps/web/app/page.tsx",
        "apps/web/app/docs/mcp/page.mdx",
        "apps/web/app/docs/page.tsx",
        "llms.txt",
        "apps/web/public/llms.txt",
        "packages/caelus-mcp/README.md",
        "packages/caelus/README.md",
        "packages/wheel/README.md",
        "packages/birth/README.md"
      ]
    },
    {
      "id": "default-body-count",
      "source": "accuracy.counts.default_bodies",
      "render": [
        "{value} bodies",
        "Thirteen in the default"
      ],
      "appearsIn": [
        "apps/web/app/features/page.tsx",
        "MCP_SPEC.md",
        "packages/caelus-mcp/README.md"
      ]
    }
  ]
}