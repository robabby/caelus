{"id": "planetary-hours-now-nyc", "prompt": "What planetary hour is it right now in New York City? NYC is at 40.71 N, 74.01 W.", "expect": {"tool": "planetary_hours", "args": {"date": "now", "lat": {"approx": 40.71, "tol": 0.3}, "lon": {"approx": -74.01, "tol": 0.3}}, "argChecks": ["lon_sign_west"]}, "tags": ["electional", "planetary_hours", "tool-select", "default-time", "west-lon"]}
{"id": "planetary-hours-dated-tokyo", "prompt": "Which planet rules the hour at 2026-06-13T09:00:00Z in Tokyo (35.68 N, 139.69 E)?", "expect": {"tool": "planetary_hours", "args": {"date": "2026-06-13T09:00:00Z", "lat": {"approx": 35.68, "tol": 0.3}, "lon": {"approx": 139.69, "tol": 0.3}}, "argChecks": ["date_is_utc", "lon_sign_east"]}, "tags": ["electional", "planetary_hours", "date", "east-lon"]}
{"id": "voc-now", "prompt": "Is the Moon void of course right now?", "expect": {"tool": "void_of_course", "args": {"date": "now"}, "argChecks": []}, "tags": ["electional", "void_of_course", "tool-select", "default-time"]}
{"id": "voc-dated", "prompt": "Was the Moon void of course at 2026-06-13T18:00:00Z, and when does it leave its sign?", "expect": {"tool": "void_of_course", "args": {"date": "2026-06-13T18:00:00Z"}, "argChecks": ["date_is_utc"]}, "tags": ["electional", "void_of_course", "date"]}
{"id": "returns-solar-tampa", "prompt": "What's my solar return chart for 2026? I was born June 10 1990 at 2:30pm in Tampa, Florida.", "expect": {"tool": "returns", "args": {"date": "1990-06-10T18:30:00Z", "lat": {"approx": 27.95, "tol": 0.3}, "lon": {"approx": -82.46, "tol": 0.3}, "body": "sun", "search_start": "2026-01-01T00:00:00Z", "search_end": "2026-12-31T23:59:59Z"}, "argChecks": ["date_is_utc", "lon_sign_west", "return_window_le_2yr"]}, "tags": ["returns", "solar-return", "tool-select", "timezone", "geocode", "west-lon"]}
{"id": "returns-lunar-relocated", "prompt": "Find my next lunar return in June 2026 and cast it for where I live now, Berlin (52.52, 13.40). Birth: 1990-06-10T18:30:00Z at 27.95, -82.46.", "expect": {"tool": "returns", "args": {"date": "1990-06-10T18:30:00Z", "lat": {"approx": 27.95, "tol": 0.2}, "lon": {"approx": -82.46, "tol": 0.2}, "body": "moon", "search_start": "2026-06-01T00:00:00Z", "search_end": "2026-06-30T23:59:59Z", "return_lat": {"approx": 52.52, "tol": 0.3}, "return_lon": {"approx": 13.40, "tol": 0.3}}, "argChecks": ["date_is_utc", "lon_sign_west", "return_window_le_2yr"]}, "tags": ["returns", "lunar-return", "relocated", "west-lon"], "note": "Birthplace lon is west; the return is relocated to Berlin (east) via return_lat/return_lon, which don't change the natal coordinates."}
{"id": "returns-window-too-wide", "prompt": "Give me all my solar returns from 2020 through 2035. Born 1990-06-10T18:30:00Z at 27.95, -82.46.", "expect": {"tool": "returns", "args": {"date": "1990-06-10T18:30:00Z", "lat": {"approx": 27.95, "tol": 0.1}, "lon": {"approx": -82.46, "tol": 0.1}, "body": "sun", "search_start": "2020-01-01T00:00:00Z", "search_end": "2035-01-01T00:00:00Z"}, "argChecks": ["date_is_utc", "lon_sign_west"], "engineError": true}, "tags": ["returns", "huge-range", "graceful-error", "west-lon"], "note": "15-year window exceeds the 2-year return guard; tool choice is still returns but the call errors. A model could also narrow the window into yearly chunks."}
{"id": "progressions-to-today", "prompt": "Progress my natal chart to today, June 13 2026 — secondary positions and the solar arc. I was born 1990-06-10T18:30:00Z.", "expect": {"tool": "progressions", "args": {"date": "1990-06-10T18:30:00Z", "target_date": "2026-06-13T00:00:00Z"}, "argChecks": ["date_is_utc", "target_after_natal"]}, "tags": ["progressions", "tool-select", "solar-arc"]}
{"id": "progressions-fiftieth", "prompt": "Compute the secondary progressions and solar-arc directions for someone born 1975-12-01T12:00:00Z, directed to their 50th birthday on 2025-12-01.", "expect": {"tool": "progressions", "args": {"date": "1975-12-01T12:00:00Z", "target_date": "2025-12-01T00:00:00Z"}, "argChecks": ["date_is_utc", "target_after_natal"]}, "tags": ["progressions", "solar-arc"]}
