{"id": "natal-midnight", "prompt": "Birth chart for someone born exactly at midnight UTC on 2005-05-05 at 30.0, 31.2 (Cairo).", "expect": {"tool": "natal_chart", "args": {"date": "2005-05-05T00:00:00Z", "lat": {"approx": 30.0, "tol": 0.2}, "lon": {"approx": 31.2, "tol": 0.2}}, "argChecks": ["date_is_utc", "lon_sign_east"]}, "tags": ["natal", "midnight", "east-lon"]}
