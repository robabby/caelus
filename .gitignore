# dependencies
node_modules/

# build outputs
dist/
apps/web/.next/
apps/web/.next-ci/
apps/web/out/
# auto-generated by `next build`; its <reference> path flips with NEXT_DIST_DIR
apps/web/next-env.d.ts
# generated by scripts/build-search-index.mjs at build time
apps/web/public/search-index.json

# env
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# archives and extracted copies (monorepo is the source of truth)
*.zip
extracted/

# python fitting caches (Horizons samples committed for Chiron reproducibility)
python/__pycache__/
.web-prose-extract.md
python/astroengine/__pycache__/

# python packaging artifacts (caelus-engine on PyPI; dists built on demand)
python/build/
python/dist/
python/*.egg-info/

# private strategy / roadmap docs — never commit to this public repo
STRATEGY.md
STRATEGY*.md

# logs
*.log
npm-debug.log*

# generated conformance stats (regenerated by the golden suite for lint:claims)
conformance-stats.json
*.tsbuildinfo

# generated eval reports (regenerated by a live model run, never committed)
packages/caelus-mcp/eval/report.json
packages/caelus-mcp/eval/report.md
python/moon_horizons_cache.json
.vercel
